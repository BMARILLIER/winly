datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  name              String?
  passwordHash      String
  role              String          @default("free") // free, pro, team, admin
  plan              String          @default("free") // free, pro
  stripeCustomerId  String?
  generationsUsed   Int             @default(0)
  generationsReset  DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  workspaces          Workspace[]
  audits              AuditResult[]
  scores              ScoreResult[]
  creatorScores       CreatorScore[]
  adminLogs           AdminLog[]
  instagramConnection InstagramConnection?
  aiInsights          AiInsight[]
  personas            Persona[]
}

model Workspace {
  id             String          @id @default(cuid())
  name           String
  profileType    String          // personal_brand, business, anonymous
  mainPlatform   String          // instagram, tiktok, twitter, linkedin, youtube
  niche          String          // ex: "fitness", "tech", "food"
  goals          String          // JSON array stringifié ["grow_audience", "monetize", ...]
  postFrequency  String          // daily, few_per_week, weekly, few_per_month, irregular
  userId         String
  createdAt      DateTime        @default(now())
  user           User            @relation(fields: [userId], references: [id])
  socialProfiles SocialProfile[]
  contentIdeas   ContentIdea[]
  savedHooks     SavedHook[]
}

model ContentIdea {
  id            String    @id @default(cuid())
  workspaceId   String
  title         String
  hook          String    // opening line / attention grabber
  format        String    // carousel, reel, single_image, text, story, thread, live
  caption       String
  cta           String    // call to action
  status        String    @default("idea") // idea, draft, ready, published
  scheduledDate String?   // ISO date string YYYY-MM-DD, null = unscheduled
  createdAt     DateTime  @default(now())
  workspace     Workspace @relation(fields: [workspaceId], references: [id])
}

model SavedHook {
  id          String    @id @default(cuid())
  workspaceId String
  text        String
  type        String    // curiosity, storytelling, educational, controversial, statistical
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model SocialProfile {
  id          String    @id @default(cuid())
  workspaceId String
  platform    String    // instagram, tiktok, twitter, linkedin
  username    String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
}

model AuditResult {
  id        String   @id @default(cuid())
  userId    String
  score     Int
  details   String // JSON stringifié
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model ScoreResult {
  id        String   @id @default(cuid())
  userId    String
  score     Int      // 0-100 global
  details   String   // JSON stringifié (pillar breakdown)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model CreatorScore {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  score       Int      // 0-100 global
  details     String   // JSON stringifié (factor breakdown)
  platform    String   // plateforme évaluée
  username    String   // username évalué
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model MissionCompletion {
  id          String   @id @default(cuid())
  workspaceId String
  missionId   String   // e.g. "mission_2026-03-09_0"
  date        String   // YYYY-MM-DD
  xp          Int
  createdAt   DateTime @default(now())

  @@unique([workspaceId, missionId])
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String   // e.g. "user.role.update", "user.delete", "setting.update"
  target    String?  // e.g. target userId or settingKey
  details   String?  // JSON stringifié (extra context)
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id])
}

model EngineRun {
  id        String   @id @default(cuid())
  engine    String   // "creator-score" | "trend-radar"
  input     String   // JSON stringifié
  output    String   // JSON stringifié
  durationMs Int
  sandbox   Boolean  @default(false) // true if run from admin sandbox
  createdAt DateTime @default(now())
}

model BetaRequest {
  id           String    @id @default(cuid())
  email        String    @unique
  status       String    @default("pending") // pending, approved, rejected
  inviteToken  String?   @unique
  approvedAt   DateTime?
  inviteSentAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model InstagramConnection {
  id                String              @id @default(cuid())
  userId            String
  igUserId          String              // Instagram user ID
  igUsername         String
  accessToken       String              // chiffré
  tokenExpiresAt    DateTime?
  lastSyncAt        DateTime?
  connectedAt       DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id])
  snapshots         InstagramSnapshot[]
  media             InstagramMedia[]

  @@unique([userId])
}

model InstagramSnapshot {
  id              String              @id @default(cuid())
  connectionId    String
  followers       Int?
  follows         Int?
  mediaCount      Int?
  reach           Int?                // reach sur les 28 derniers jours si dispo
  impressions     Int?
  profileViews    Int?
  createdAt       DateTime            @default(now())
  connection      InstagramConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
}

model InstagramMedia {
  id              String              @id @default(cuid())
  connectionId    String
  igMediaId       String              // ID Instagram du media
  mediaType       String              // IMAGE, VIDEO, CAROUSEL_ALBUM
  caption         String?
  permalink       String?
  timestamp       DateTime
  likeCount       Int                 @default(0)
  commentsCount   Int                 @default(0)
  reach           Int?
  impressions     Int?
  saved           Int?
  createdAt       DateTime            @default(now())
  connection      InstagramConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, igMediaId])
}

model AiInsight {
  id          String   @id @default(cuid())
  userId      String
  category    String   // strategy, timing, audience, growth
  title       String
  description String
  impact      String   // high, medium, low
  metric      String?  // donnée chiffrée associée (ex: "4.2%", "+12%")
  source      String   @default("local") // "local" = règles déterministes, "ai" = Claude/LLM
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model AiCache {
  id        String   @id @default(cuid())
  promptKey String   @unique // hash du prompt (type + sujet + niche)
  type      String   // "hooks", "content", "insights"
  response  String   // JSON stringifié de la réponse
  createdAt DateTime @default(now())
}

model CreatorIdentity {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  // Qui je suis
  bio         String?  // courte description personnelle
  tone        String?  // ton de communication : fun, pro, inspirant, provocateur...
  values      String?  // valeurs clés (authenticité, partage, excellence...)
  story       String?  // parcours, histoire personnelle
  // Ce que je fais
  products    String?  // produits/services (cours, sets, coaching, merch...)
  expertise   String?  // domaines d'expertise spécifiques
  audience    String?  // qui est mon audience cible
  // Ma marque
  catchphrases String? // expressions/phrases signatures
  avoid       String?  // ce que je ne veux JAMAIS dire/faire
  references  String?  // créateurs/marques qui m'inspirent
  // Notes libres
  freeNotes   String?  // tout ce qui n'entre pas dans les autres champs
  updatedAt   DateTime @updatedAt
}

model CompetitorInspo {
  id          String   @id @default(cuid())
  workspaceId String
  source      String   // ex: "@dj_snake", "concurrent", url...
  text        String   // le texte du post concurrent
  notes       String?  // notes optionnelles (ex: "200k vues", "bon hook")
  createdAt   DateTime @default(now())
}

model ChatConversation {
  id          String        @id @default(cuid())
  workspaceId String
  contactName String        // nom du contact (marque, follower, prospect)
  contactType String        @default("prospect") // prospect, brand, follower, partner
  platform    String        @default("instagram") // instagram, tiktok, twitter, linkedin, email
  status      String        @default("active") // active, archived, converted
  score       Int           @default(0) // score d'intérêt 0-100
  tags        String?       // JSON array stringifié ["sponsoring", "collab", ...]
  notes       String?       // notes internes sur la conversation
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  messages    ChatMessage[]
  insights    ChatInsight[]
}

model ChatMessage {
  id             String           @id @default(cuid())
  conversationId String
  sender         String           // "me" ou nom du contact
  content        String
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model ChatInsight {
  id             String           @id @default(cuid())
  conversationId String
  type           String           // interest, emotion, opportunity, suggestion
  label          String           // ex: "Intérêt fort", "Prêt à acheter"
  description    String
  priority       String           @default("medium") // low, medium, high
  dismissed      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model Persona {
  id          String   @id @default(cuid())
  userId      String
  name        String
  niche       String
  tone        String
  platform    String
  bio         String
  catchphrase String
  visualStyle String
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SystemSetting {
  key       String   @id
  value     String   // JSON stringifié
  updatedAt DateTime @updatedAt
}
